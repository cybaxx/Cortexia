# TRIBE Modal: full HTTPS URL for the `extract_batch_bsv` (extract-batch-bsv) web endpoint.
# It must accept JSON: {"catalyst_text": "...", "agents": [...]}. The old multipart
# `extract-bsv` URL will return 404 to this app—redeploy with `modal deploy modal_app.py`
# in `backend/` and paste the exact URL shown for the batch function.
# After deploy, use the stable production URL (not the -dev tunnel from `modal serve`).
TRIBE_MODAL_URL=

# Optional: only if Modal web endpoint uses requires_proxy_auth=True
# TRIBE_MODAL_KEY=
# TRIBE_MODAL_SECRET=

# K2 Think — OpenAI-compatible chat at api.k2think.ai
# You need a key; URL defaults in code to https://api.k2think.ai/v1/chat/completions
# Use either name for the same bearer token (see app.config ifm_api_key aliases):
# IFM_API_KEY=
# K2_THINK_API_KEY=
# Optional: override (set empty to force local mock K2)
# IFM_API_URL=
# IFM_K2_MODEL=MBZUAI-IFM/K2-Think-v2

# ElevenLabs (optional)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_STT_MODEL=scribe_v2
