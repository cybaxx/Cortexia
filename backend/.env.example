# Primary neural pipeline mode.
# - framework: use the vendored tribe_neural pipeline locally in-process
# - modal: call a remote Modal endpoint
TRIBE_RUNTIME_MODE=framework

# Hugging Face token with access to gated TRIBE dependencies such as
# meta-llama/Llama-3.2-3B. Required for framework mode.
HF_TOKEN=

# Local cache/data directory for tribe_neural resources.
# TRIBE_DATA_DIR=

# TRIBE Modal: only used when TRIBE_RUNTIME_MODE=modal.
# Full HTTPS URL for the `extract_batch_bsv` web endpoint.
TRIBE_MODAL_URL=

# Optional: only if Modal web endpoint uses requires_proxy_auth=True
# TRIBE_MODAL_KEY=
# TRIBE_MODAL_SECRET=

# K2 Think — OpenAI-compatible chat at api.k2think.ai
# You need a key; URL defaults in code to https://api.k2think.ai/v1/chat/completions
# Use either name for the same bearer token (see app.config ifm_api_key aliases):
# IFM_API_KEY=
# K2_THINK_API_KEY=
# Optional: override (set empty to force local mock K2)
# IFM_API_URL=
# IFM_K2_MODEL=MBZUAI-IFM/K2-Think-v2

# ElevenLabs (optional)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_STT_MODEL=scribe_v2
