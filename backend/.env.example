# Primary neural pipeline mode.
# - framework: use the vendored tribe_neural pipeline locally in-process
# - modal: call a remote Modal endpoint
TRIBE_RUNTIME_MODE=framework

# Framework device override (optional — leave unset for auto-detection).
# Allowed values: cuda, mps, cpu
# On Apple Silicon Macs, auto-detection picks 'mps' automatically.
# TRIBE_DEVICE=

# Hugging Face token with access to gated TRIBE dependencies such as
# meta-llama/Llama-3.2-3B. Required for framework mode.
HF_TOKEN=

# Local cache/data directory for tribe_neural resources.
# TRIBE_DATA_DIR=

# TRIBE Modal: only used when TRIBE_RUNTIME_MODE=modal.
# Full HTTPS URL for the `extract_batch_bsv` web endpoint.
TRIBE_MODAL_URL=

# Optional: only if Modal web endpoint uses requires_proxy_auth=True
# TRIBE_MODAL_KEY=
# TRIBE_MODAL_SECRET=

# K2 Think — OpenAI-compatible chat at api.k2think.ai
# You need a key; URL defaults in code to https://api.k2think.ai/v1/chat/completions
# Use either name for the same bearer token (see app.config ifm_api_key aliases):
# IFM_API_KEY=
# K2_THINK_API_KEY=
# Optional: override (set empty to force local mock K2)
# IFM_API_URL=
# IFM_K2_MODEL=MBZUAI-IFM/K2-Think-v2

# ElevenLabs (optional)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_STT_MODEL=scribe_v2

# Action Center live research (optional — local DuckDuckGo used when absent)
# TAVILY_API_KEY=
# FIRECRAWL_API_KEY=
# action_center_max_sources=6       # 2–12, max web sources to include
# action_center_timeout_seconds=35  # 5–120, timeout for provider calls

# ── Simulation tuning ─────────────────────────────────────────────
# simulate_population_size=72          # 24–220, agents per simulation
# simulate_total_timeout_seconds=180   # 10–3600, hard pipeline timeout
# simulate_tribe_timeout_seconds=120   # 5–600, TRIBE batch timeout
# simulate_k2_timeout_seconds=90       # 5–300, per-agent LLM timeout
# simulate_k2_concurrency=10           # 1–32, concurrent LLM calls
# simulate_source_fetch_timeout_seconds=15  # 1–120, source URL fetch timeout

# ── Infrastructure ─────────────────────────────────────────────────
# pipeline_db_path=        # defaults to backend/cortexia.db
# cors_origins=            # comma-separated, defaults to localhost:3000,8080,5173
